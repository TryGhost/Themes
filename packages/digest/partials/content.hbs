<header class="gh-article-header gh-canvas">
    <div class="gh-meta-share">
        <div class="gh-article-meta">
            {{#is "home"}}
                <span class="gh-article-label">{{t "Latest issue"}}</span>
            {{/is}}
            <time class="gh-article-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="DD MMM YYYY"}}</time>
        </div>
        <a href="#/share" class="gh-button-share">{{t "Share"}}</a>
    </div>

    <h1 class="gh-article-title">{{title}}</h1>

    {{#if custom_excerpt}}
        <p class="gh-article-excerpt">{{custom_excerpt}}</p>
    {{/if}}
</header>

{{> "feature-image"}}

<section class="gh-content gh-canvas">
    {{content}}
</section>

{{#if comments}}
    <div class="gh-comments gh-canvas">
        {{comments}}
    </div>
{{/if}}

<footer class="gh-article-footer gh-canvas{{#if @site.comments_enabled}}{{#unless @member}} no-border{{/unless}}{{#unless access}} no-border{{/unless}}{{/if}}">
    <nav class="gh-navigation">
        <div class="gh-navigation-previous">
            {{#prev_post}}
                <a class="gh-navigation-link u-hover reverse" href="{{url}}">
                    <span class="gh-navigation-arrow-container">
                        <span class="u-hover-arrow">{{> icons/chevron-left}}</span>
                        <span class="u-hover-arrow">{{> icons/chevron-left}}</span>
                    </span>
                    <span class="gh-navigation-desktop-only">{{t "Previous issue"}}</span><span class="gh-navigation-mobile-only">{{t "Previous"}}</span>
                </a>
            {{/prev_post}}
        </div>

        <div>
            {{#get "posts" fields="id" limit="10" page="2" as |secondPage|}}
                {{#if secondPage}}
                    <a class="gh-navigation-middle" href="/page/2">{{t "Browse all issues"}}</a>
                {{/if}}
            {{/get}}
        </div>

        <div class="gh-navigation-next">
            {{#next_post}}
                <a class="gh-navigation-link u-hover" href="{{url}}">
                    <span class="gh-navigation-desktop-only">{{t "Next issue"}}</span><span class="gh-navigation-mobile-only">{{t "Next"}}</span>
                    <span class="gh-navigation-arrow-container">
                        <span class="u-hover-arrow">{{> icons/chevron-right}}</span>
                        <span class="u-hover-arrow">{{> icons/chevron-right}}</span>
                    </span>
                </a>
            {{/next_post}}
        </div>
    </nav>
</footer>