{{!--
    Parameters:
    * footerText (text)
--}}

<footer class="gh-foot gh-outer">
    <div class="gh-foot-inner gh-inner">
        <div class="gh-foot-center">
            <div class="gh-social-links">
                {{#social_accounts @site}}
                    <a href="{{href}}" target="_blank" rel="noopener" aria-label="{{name}}">
                        {{#> (concat "icons/" type)}}
                            {{!-- Fallback when no per-platform icon partial exists --}}
                            <span>{{name}}</span>
                        {{/undefined}}
                    </a>
                {{/social_accounts}}
            </div>
            <nav class="gh-foot-menu">
                {{navigation type="secondary"}}
            </nav>
        </div>

        <div class="gh-copyright">
            {{#unless footerText}}
                {{@site.title}} &copy; {{date format="YYYY"}}. {{{t "Powered by {ghostlink}" ghostlink="<a href=\"https://ghost.org/\" target=\"_blank\" rel=\"noopener\">Ghost</a>"}}}
            {{else}}
                {{footerText}}
            {{/unless}}
        </div>
    </div>
</footer>