{{!< default}}

<main id="gh-main" class="gh-main gh-canvas">
    <section class="gh-pagehead">
        <header class="gh-pagehead-content">
            <h1 class="gh-pagehead-title">{{t "Archive"}}</h1>

            <div class="gh-pagehead-description">
                {{#if description}}
                    {{description}}
                {{else}}
                {{plural ../pagination.total 
                    empty=(t "A collection of 0 posts") singular=(t "A collection of 1 post") 
                    plural=(t "A collection of {numberOfPosts} posts" numberOfPosts=../pagination.total) }}
                {{/if}}
            </div>
        </header>
    </section>

    <div class="gh-feed">
        {{#match pagination.page 2}}
            {{#get "posts" limit=@config.posts_per_page as |recent|}}
                {{#foreach recent}}
                    {{> "loop"}}
                {{/foreach}}
            {{/get}}
        {{/match}}
        {{#foreach posts}}
            {{> "loop"}}
        {{/foreach}}
    </div>
</main>