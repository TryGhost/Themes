{
    "private": true,
    "name": "root",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "gulp",
        "symlink": "gulp symlink",
        "test": "gulp test",
        "test:ci": "gulp testCI",
        "zip": "gulp zip",
        "build": "gulp buildAll",
        "ship:shared": "npm --prefix packages/_shared version patch --no-git-tag-version"
    },
    "devDependencies": {
        "autoprefixer": "10.4.27",
        "beeper": "2.1.0",
        "concurrently": "9.2.1",
        "cssnano": "7.1.4",
        "gscan": "5.4.3",
        "gulp": "5.0.1",
        "gulp-compile-handlebars": "0.6.1",
        "gulp-concat": "2.6.1",
        "gulp-livereload": "4.0.2",
        "gulp-postcss": "10.0.0",
        "gulp-uglify": "3.0.2",
        "gulp-zip": "5.1.0",
        "ordered-read-streams": "2.0.0",
        "postcss": "8.5.9",
        "postcss-easy-import": "4.0.0",
        "pump": "3.0.4",
        "yargs": "18.0.0"
    },
    "browserslist": [
        "defaults"
    ],
    "renovate": {
        "extends": [
            "@tryghost:theme"
        ],
        "ignoreDeps": ["gulp-zip"]
    }
}
